DATABASE_URL=postgres://auth:dev-password@localhost:5432/auth
SESSION_SECRET=dev-session-secret-change-in-production
JWT_SIGNING_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRY=3600
# CORS allowlist is auto-derived from PUBLIC_ORIGIN + appsConfig at boot.
# Leave this unset in the common case; only set for edge-case overrides.
ALLOWED_ORIGINS=

# Owner account — resynced from these on every auth boot.
ADMIN_USERNAME=rob
ADMIN_PASSWORD=test123

# Absolute path to the workspace-root appsConfig.json (host dev; Docker sets its own).
APPS_CONFIG_PATH=

# The origin users' browsers see for the shell. Auth derives every sub-app
# iframe URL from this: localhost / IP hosts get port-based URLs
# (http://<host>:<port>), proper domains get subdomain-based URLs
# (https://{subdomain ?? id}.<domain>). Defaults to http://localhost:3000
# when unset.
PUBLIC_ORIGIN=http://localhost:3000
