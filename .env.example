DATABASE_URL=postgres://auth:dev-password@localhost:5432/auth
SESSION_SECRET=dev-session-secret-change-in-production
JWT_SIGNING_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRY=3600
ALLOWED_ORIGINS=http://localhost:3000

# Owner account — resynced from these on every auth boot.
ADMIN_USERNAME=rob
ADMIN_PASSWORD=test123

# Absolute path to the workspace-root appsConfig.json (host dev; Docker sets its own).
APPS_CONFIG_PATH=
